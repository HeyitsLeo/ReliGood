# ==================== Runtime ====================
NODE_ENV=development
ADAPTER_MODE=mock
LOG_LEVEL=info

# ==================== Ports ====================
BACKEND_PORT=3001
ADMIN_PORT=3000

# ==================== Database ====================
DATABASE_URL=postgresql://zamgo:zamgo_dev@127.0.0.1:5432/zamgo
REDIS_URL=redis://127.0.0.1:6379

# ==================== Twilio WhatsApp Sandbox ====================
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio Sandbox shared number (default: +14155238886)
TWILIO_WHATSAPP_NUMBER=+14155238886

# ==================== LLM (Qwen via OpenAI-compatible API) ====================
# Get API key from https://dashscope.console.aliyun.com/
OPENAI_API_KEY=your_dashscope_api_key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_CHAT_MODEL=qwen-plus
OPENAI_VISION_MODEL=qwen-vl-plus
OPENAI_EMBEDDING_MODEL=text-embedding-v3

# ==================== WhatsApp Cloud API (备用，当前使用 Twilio) ====================
# WHATSAPP_PHONE_NUMBER_ID=000000000000000
# WHATSAPP_ACCESS_TOKEN=mock-wa-token
# WHATSAPP_APP_SECRET=dev-secret
# WHATSAPP_VERIFY_TOKEN=zamgo-verify-token

# ==================== Shopify (disabled — uncomment when ready) ====================
# SHOPIFY_STORE_DOMAIN=zamgo.myshopify.com
# SHOPIFY_ADMIN_TOKEN=mock-shopify-token
# SHOPIFY_WEBHOOK_SECRET=mock-shopify-webhook

# ==================== 1688 (mock) ====================
ALIBABA_APP_KEY=mock-app-key
ALIBABA_APP_SECRET=mock-app-secret
ALIBABA_ACCESS_TOKEN=mock-access-token

# ==================== Rates (fallback) ====================
DEFAULT_FX_CNY_ZMW=3.80
DEFAULT_FX_USD_ZMW=26.50
DEFAULT_SHIP_PER_KG_USD=9

# ==================== Supabase (Storage for product images) ====================
# Get these from https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ==================== Frontend ====================
NEXT_PUBLIC_API_URL=http://localhost:3001
