# ==================== Runtime ====================
NODE_ENV=development
ADAPTER_MODE=mock
LOG_LEVEL=info

# ==================== Ports ====================
BACKEND_PORT=3001
ADMIN_PORT=3000

# ==================== Database ====================
DATABASE_URL=postgresql://zamgo:zamgo_dev@localhost:5432/zamgo
REDIS_URL=redis://localhost:6379

# ==================== WhatsApp Cloud API ====================
# Get these from Meta Business → WhatsApp → API Setup:
#   https://developers.facebook.com/apps/<APP_ID>/whatsapp-business/wa-dev-console/
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_ACCESS_TOKEN=mock-wa-token
# App Secret from Meta Business → App Settings → Basic:
WHATSAPP_APP_SECRET=dev-secret
# Arbitrary string you choose when subscribing the webhook in Meta dashboard:
WHATSAPP_VERIFY_TOKEN=zamgo-verify-token

# ==================== OpenAI ====================
OPENAI_API_KEY=mock-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# ==================== Twilio WhatsApp Sandbox ====================
# Get these from https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio Sandbox shared number (default: +14155238886)
# TWILIO_WHATSAPP_NUMBER=+14155238886

# ==================== Shopify (disabled — uncomment when ready) ====================
# SHOPIFY_STORE_DOMAIN=zamgo.myshopify.com
# SHOPIFY_ADMIN_TOKEN=mock-shopify-token
# SHOPIFY_WEBHOOK_SECRET=mock-shopify-webhook

# ==================== 1688 (mock) ====================
ALIBABA_APP_KEY=mock-app-key
ALIBABA_APP_SECRET=mock-app-secret
ALIBABA_ACCESS_TOKEN=mock-access-token

# ==================== Rates (fallback) ====================
DEFAULT_FX_CNY_ZMW=3.80
DEFAULT_FX_USD_ZMW=26.50
DEFAULT_SHIP_PER_KG_USD=9

# ==================== Frontend ====================
NEXT_PUBLIC_API_URL=http://localhost:3001
